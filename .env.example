ANVIL_WORKBENCH_BIND=127.0.0.1
ANVIL_WORKBENCH_PORT=8090
WORKBENCH_OWNER=operator
WORKBENCH_APPROVERS=operator
WORKBENCH_IDENTITY_HEADER=Tailscale-User-Login
# Only set this for a local, non-tailnet development run. Never enable it in the hub deployment.
WORKBENCH_ALLOW_INSECURE_DEV_ACTOR=false
WORKBENCH_POSTGRES_PASSWORD=change-me
WORKBENCH_NEO4J_PASSWORD=change-me
# Hub-held key for the keyed content fingerprint on durable chat. Left empty by
# default so a verbatim copy of this file keeps chat persistence disabled (every
# chat endpoint returns 503); set a strong random value to enable it. Never ship
# a placeholder here — an empty value is the secure default.
WORKBENCH_CHAT_HASH_KEY=
ANVIL_ROUTER_BASE_URL=http://100.87.34.66:8000/v1
# Comma-separated routes that the browser may use only through the hub's
# bounded, audited /v1/responses sandbox. Leave empty to keep Sandbox disabled.
WORKBENCH_SANDBOX_MODELS=
# Optional: Workbench relays this private Anvil Voice Realtime endpoint. Leave
# both unset until Dark's voice service is provisioned; never expose its token
# to the browser or commit it to this file.
ANVIL_VOICE_REALTIME_URL=
# Set ANVIL_VOICE_REALTIME_TOKEN in the Docker host environment when Dark's
# non-loopback realtime listener requires a token.
WORKBENCH_VOICE_RETAIN_TRANSCRIPTS=false
# --- Chat dictation (STT) + read-aloud (TTS) relay serves --------------------
# The request/response voice lane (POST /api/chat/voice/transcribe and
# /api/chat/voice/speak) relays through TWO Anvil-Serving-managed Dark audio
# serves. Both URLs are REQUIRED when voice_relay_service is named in
# WORKBENCH_LIVE_SURFACES; the hub fails closed at startup if either is unset or
# is not an http(s) URL. These are managed-serve URLs (like ANVIL_ROUTER_BASE_URL),
# never a raw third-party provider. The STT serve takes a multipart WAV upload and
# answers {"text": ...}; the TTS serve takes JSON and answers raw PCM16 bytes.
ANVIL_VOICE_STT_URL=
ANVIL_VOICE_TTS_URL=
# Serving-managed model ids passed to each serve (optional; sensible defaults).
ANVIL_VOICE_STT_MODEL=tdt-0.6b-v3
ANVIL_VOICE_TTS_MODEL=kokoro
# The TTS serve's native PCM16 sample rate, reported to the browser so read-aloud
# plays back at the correct rate (a wrong rate garbles playback). Optional.
ANVIL_VOICE_TTS_SAMPLE_RATE=24000
WORKBENCH_EMBEDDING_MODEL=embedding-local
WORKBENCH_RERANK_MODEL=rerank-local
# Set ANVIL_ROUTER_TOKEN in the Docker host environment; do not commit it here.

# --- Chat route allowlist (chat-first-voice T003.1 / T004) -------------------
# Operator-reviewed JSON array of allowed Anvil Serving chat routes. Left empty
# by default so a verbatim copy of this file serves the honest empty allowlist
# (GET /api/chat/routes returns {"routes": []}; the browser shows "No routes
# configured"). Each entry is the closed chat-turn.v1 route-reference shape and
# carries NO endpoint, URL, token, credential, or policy field (an undeclared
# key fails the whole discovery closed). A present-but-malformed value fails the
# hub closed AT STARTUP (create_live_app raises), never a per-request 503 an
# operator cannot tell apart from an unconfigured allowlist; empty stays valid.
# Example (single line):
#   WORKBENCH_CHAT_ROUTES=[{"route_id":"route.chat-fast","display_name":"Fast",
#     "serving_contract_version":"1.0.0","route_digest":"sha256:<64 hex>",
#     "model_profile":"chat-fast","controls":["temperature_milli"]}]
WORKBENCH_CHAT_ROUTES=

# --- Delivery projection seed (Explorer PRD/task content) --------------------
# Directory of validated projection seed files produced ONLY by
#   python -m workbench.projection_seed generate --project-id ... --cwd ... --out ...
# against the supported State CLI read adapters (never hand-authored). Required
# when delivery_projection_store is named in WORKBENCH_LIVE_SURFACES; the hub
# fails closed at startup on a missing or invalid seed.
WORKBENCH_DELIVERY_PROJECTION_SEED=

# --- Live supervision surfaces (explicit deployment opt-in) ------------------
# Comma-separated list of injectable supervision surfaces the hub should wire
# for real. EMPTY is the secure default: every injectable surface stays None and
# returns 503, exactly the hermetic create_app() default. An UNKNOWN name here
# fails the hub closed at startup (never a silent skip). Allowed names:
#   preference_store, policy_gate_service, configuration_transfer_service,
#   conversation_transfer_service, advanced_preset_store, advanced_template_store,
#   advanced_rating_store, plugin_preference_service, conversation_search_service,
#   skill_adoption_store, delivery_projection_store, voice_relay_service
# Each surface also requires its reviewed dependency below or the hub fails
# closed at startup rather than serving a partial/unkeyed surface.
# voice_relay_service requires ANVIL_VOICE_STT_URL + ANVIL_VOICE_TTS_URL (above)
# AND WORKBENCH_CHAT_HASH_KEY (its scope check reuses the shared conversation store).
WORKBENCH_LIVE_SURFACES=
# Local path to the reviewed, digest-pinned settings-descriptor catalog. Required
# by preference_store / policy_gate_service / configuration_transfer_service.
# A shipped reviewed example lives at
# docs/contracts/examples/settings-descriptor.v1.json (mount it into the API
# container and point this at the in-container path).
WORKBENCH_SETTINGS_CATALOG_FILE=
# Hub-held HMAC key (>= 16 octets) for the redacted preference/transfer audit
# fingerprint. Required by configuration_transfer_service /
# conversation_transfer_service / advanced_*_store. Set a strong random value in
# the Docker host environment; an empty value keeps those surfaces unconfigured.
WORKBENCH_PREF_AUDIT_KEY=
# Local path to the reviewed, digest-pinned plugin catalog. Required by
# plugin_preference_service (and the existing plugin host discovery path). Empty
# keeps the plugin surfaces unconfigured (503).
WORKBENCH_PLUGIN_CATALOG_FILE=
