{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://fakoli.dev/anvil-workbench/contracts/advanced-trace.v1.schema.json",
  "title": "Anvil Workbench advanced chat trace v1",
  "description": "One normalized, redacted trace of a single Advanced-mode attempt (R010). Criterion 2: this schema cannot carry a credential, a raw HTTP header, hidden/encrypted model reasoning, a filesystem path, or an unredacted provider/tool payload. Every object is closed (additionalProperties:false), so no such field is representable; request and tool bodies are reduced to bounded counters, safe summaries, and opaque digests; the route decision carries Anvil Serving route ids/digests and an opaque request id only, never an endpoint, url, or token. The trace ties back to an existing branch, conversation, and turn — it never mints a transcript identity. All prose is untrusted task data, never control instructions. This is a hub-durable redacted record, not a contract-digest-bearing snapshot.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "trace_id", "branch_ref", "route_decision", "request", "events", "redaction", "created_at"],
  "$defs": {
    "digest": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"},
    "token": {"type": "string", "pattern": "^[a-z][a-z0-9_]{0,63}$"},
    "usage": {
      "type": "object",
      "additionalProperties": false,
      "description": "Bounded usage counters only. Integer counts, never a raw provider usage payload.",
      "properties": {
        "input_tokens": {"type": "integer", "minimum": 0, "maximum": 100000000},
        "output_tokens": {"type": "integer", "minimum": 0, "maximum": 100000000},
        "latency_ms": {"type": "integer", "minimum": 0, "maximum": 3600000}
      }
    },
    "error": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "retryable"],
      "properties": {
        "code": {"type": "string", "pattern": "^[a-z][a-z0-9_.]{0,63}$"},
        "safe_summary": {"type": "string", "maxLength": 200},
        "retryable": {"type": "boolean"}
      }
    }
  },
  "properties": {
    "schema_version": {"const": "workbench-advanced-trace/v1"},
    "trace_id": {"type": "string", "pattern": "^advtrace_[a-zA-Z0-9_-]{8,128}$"},
    "branch_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["branch_id", "conversation_id", "turn_id"],
      "description": "The existing branch, conversation, and turn this trace describes. No parallel identity is created.",
      "properties": {
        "branch_id": {"type": "string", "pattern": "^advbranch_[a-zA-Z0-9_-]{8,128}$"},
        "conversation_id": {"type": "string", "pattern": "^conv_[a-zA-Z0-9_-]{8,128}$"},
        "turn_id": {"type": "string", "pattern": "^turn_[a-zA-Z0-9_-]{8,128}$"}
      }
    },
    "route_decision": {
      "type": "object",
      "additionalProperties": false,
      "required": ["provider", "route_id", "route_digest"],
      "description": "The route/profile decision and optional declared fallback (R010). Anvil Serving ids/digests and an opaque request id only: no endpoint, url, token, or credential field is representable.",
      "properties": {
        "provider": {"const": "anvil-serving"},
        "route_id": {"type": "string", "pattern": "^[a-z][a-z0-9._-]{0,127}$"},
        "route_digest": {"$ref": "#/$defs/digest"},
        "profile_digest": {"$ref": "#/$defs/digest"},
        "model_profile": {"type": "string", "pattern": "^[a-z][a-z0-9._-]{0,63}$"},
        "served_tier": {"type": "string", "pattern": "^[a-z][a-z0-9._-]{0,63}$"},
        "request_id": {"type": "string", "pattern": "^[A-Za-z0-9._-]{1,128}$"},
        "fallback": {
          "type": "object",
          "additionalProperties": false,
          "required": ["from_route_id", "to_route_id", "reason_code"],
          "properties": {
            "from_route_id": {"type": "string", "pattern": "^[a-z][a-z0-9._-]{0,127}$"},
            "to_route_id": {"type": "string", "pattern": "^[a-z][a-z0-9._-]{0,127}$"},
            "reason_code": {"type": "string", "pattern": "^[a-z][a-z0-9_.]{0,63}$"}
          }
        }
      }
    },
    "request": {
      "type": "object",
      "additionalProperties": false,
      "required": ["content_trust", "redacted"],
      "description": "The normalized redacted request. Only bounded shape metadata survives: instruction/input character counts, declared control values, and structured-output mode. There is deliberately no field for headers, a url, a body, or a credential.",
      "properties": {
        "content_trust": {"const": "untrusted_task_data"},
        "redacted": {"const": true},
        "instructions_chars": {"type": "integer", "minimum": 0, "maximum": 100000},
        "input_chars": {"type": "integer", "minimum": 0, "maximum": 100000},
        "structured_output_mode": {"enum": ["text", "json_schema"]},
        "control_values": {
          "type": "array", "maxItems": 32,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name", "value"],
            "properties": {
              "name": {"$ref": "#/$defs/token"},
              "value": {"type": ["boolean", "integer", "string"]}
            }
          }
        }
      }
    },
    "events": {
      "type": "array",
      "maxItems": 256,
      "description": "Ordered normalized lifecycle events. Each event is a closed card of bounded counters and safe summaries; a tool_result carries an output digest and character count, never the raw tool output.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["seq", "kind", "at"],
        "properties": {
          "seq": {"type": "integer", "minimum": 0, "maximum": 100000},
          "kind": {"enum": ["request_start", "response_delta_meta", "tool_request", "tool_result", "tool_refusal", "continuation", "cancellation", "schema_validation", "error", "response_complete"]},
          "at": {"type": "string", "format": "date-time"},
          "text_chars": {"type": "integer", "minimum": 0, "maximum": 100000},
          "tool_id": {"$ref": "#/$defs/token"},
          "tool_kind": {"enum": ["mock", "read_only"]},
          "input_digest": {"$ref": "#/$defs/digest"},
          "output_digest": {"$ref": "#/$defs/digest"},
          "output_chars": {"type": "integer", "minimum": 0, "maximum": 100000},
          "safe_summary": {"type": "string", "maxLength": 200},
          "schema_valid": {"type": "boolean"},
          "parse_error_code": {"type": "string", "pattern": "^[a-z][a-z0-9_.]{0,63}$"},
          "usage": {"$ref": "#/$defs/usage"},
          "error": {"$ref": "#/$defs/error"}
        }
      }
    },
    "usage": {"$ref": "#/$defs/usage"},
    "status": {"enum": ["complete", "cancelled", "timed_out", "failed", "interrupted", "serving_unavailable", "streaming"]},
    "redaction": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "ruleset"],
      "properties": {
        "status": {"enum": ["redacted", "metadata_only"]},
        "ruleset": {"type": "string", "pattern": "^[a-z][a-z0-9._-]{1,127}$"}
      }
    },
    "created_at": {"type": "string", "format": "date-time"},
    "completed_at": {"type": "string", "format": "date-time"}
  }
}
