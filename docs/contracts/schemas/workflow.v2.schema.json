{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://fakoli.dev/anvil-workbench/contracts/workflow.v2.schema.json",
  "title": "Anvil Workbench workflow v2",
  "description": "A declarative workflow. Schema validation checks shape only; implementation validates graph reachability, acyclicity, references, catalog/profile authorization, and immutable snapshot semantics.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "id", "revision", "entry", "steps"],
  "properties": {
    "schema_version": {"const": "workbench-workflow/v2"},
    "id": {"$ref": "#/$defs/id"},
    "revision": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "entry": {"$ref": "#/$defs/id"},
    "description": {"type": "string", "maxLength": 1000},
    "steps": {"type": "array", "minItems": 1, "maxItems": 64, "items": {"$ref": "#/$defs/step"}}
  },
  "$defs": {
    "id": {"type": "string", "pattern": "^[a-z][a-z0-9]*(?:[_-][a-z0-9]+)*$"},
    "next": {"type": "array", "maxItems": 16, "items": {"$ref": "#/$defs/id"}},
    "operation_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["provider", "id", "contract_version"],
      "properties": {
        "provider": {"type": "string", "pattern": "^[a-z][a-z0-9-]{1,62}$"},
        "id": {"type": "string", "pattern": "^[a-z][a-z0-9]*(?:[._][a-z0-9]+)*$"},
        "contract_version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"}
      }
    },
    "step": {
      "oneOf": [
        {"$ref": "#/$defs/operation_step"},
        {"$ref": "#/$defs/agent_step"},
        {"$ref": "#/$defs/approval_step"},
        {"$ref": "#/$defs/control_step"}
      ]
    },
    "operation_step": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "kind", "operation", "inputs", "next"],
      "properties": {
        "id": {"$ref": "#/$defs/id"},
        "kind": {"const": "operation"},
        "operation": {"$ref": "#/$defs/operation_ref"},
        "inputs": {"type": "object", "description": "Literals and implementation-validated allowlisted references only; no interpolation or expressions."},
        "next": {"$ref": "#/$defs/next"}
      }
    },
    "agent_step": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "kind", "model_profile", "skills", "next"],
      "properties": {
        "id": {"$ref": "#/$defs/id"},
        "kind": {"const": "agent"},
        "model_profile": {"type": "string", "pattern": "^[a-z][a-z0-9._-]{1,127}$"},
        "skills": {"type": "array", "maxItems": 16, "items": {"type": "object", "additionalProperties": false, "required": ["id", "digest"], "properties": {"id": {"type": "string", "pattern": "^[a-z][a-z0-9:_-]{1,127}$"}, "digest": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"}}}},
        "next": {"$ref": "#/$defs/next"}
      }
    },
    "approval_step": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "kind", "approval_action", "next"],
      "properties": {
        "id": {"$ref": "#/$defs/id"},
        "kind": {"const": "approval_wait"},
        "approval_action": {"enum": ["commit_pr", "merge_and_accept", "deployment", "model_policy"]},
        "next": {"$ref": "#/$defs/next"}
      }
    },
    "control_step": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "kind", "next"],
      "properties": {
        "id": {"$ref": "#/$defs/id"},
        "kind": {"enum": ["condition", "fan_out", "join", "evidence_submit", "reconcile", "cancel"]},
        "next": {"$ref": "#/$defs/next"}
      }
    }
  }
}
