{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://fakoli.dev/anvil-workbench/contracts/run-context.v1.schema.json",
  "title": "Anvil Workbench run context v1",
  "description": "A bounded, immutable runtime context for one model turn. It deliberately excludes local paths, credentials, raw transcripts, and unrestricted commands.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "context_id", "identity", "task", "workflow", "cursor", "capabilities", "constraints"],
  "properties": {
    "schema_version": {"const": "workbench-run-context/v1"},
    "context_id": {"type": "string", "pattern": "^ctx_[a-zA-Z0-9_-]{8,128}$"},
    "identity": {"type": "object", "additionalProperties": false, "required": ["run_id", "session_id", "bridge_id", "worktree_name"], "properties": {"run_id": {"type": "string"}, "session_id": {"type": "string"}, "task_id": {"type": "string"}, "bridge_id": {"type": "string"}, "worktree_name": {"type": "string", "pattern": "^[a-zA-Z0-9._-]{1,128}$"}, "request_id": {"type": "string"}, "traceparent": {"type": "string", "maxLength": 256}}},
    "task": {"type": "object", "additionalProperties": false, "required": ["title", "acceptance_criteria", "work_packet_digest"], "properties": {"title": {"type": "string", "maxLength": 500}, "acceptance_criteria": {"type": "array", "maxItems": 64, "items": {"type": "string", "maxLength": 2000}}, "scope": {"type": "array", "maxItems": 64, "items": {"type": "string", "maxLength": 500}}, "verification_plan": {"type": "array", "maxItems": 32, "items": {"type": "string", "maxLength": 1000}}, "work_packet_digest": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"}}},
    "workflow": {"type": "object", "additionalProperties": false, "required": ["id", "revision", "digest", "catalog_digest", "capability_profile_digest"], "properties": {"id": {"type": "string"}, "revision": {"type": "string"}, "digest": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"}, "catalog_digest": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"}, "capability_profile_digest": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"}}},
    "cursor": {"type": "object", "additionalProperties": false, "required": ["step_id", "attempt"], "properties": {"step_id": {"type": "string"}, "attempt": {"type": "integer", "minimum": 1}, "completed_receipts": {"type": "array", "maxItems": 32, "items": {"type": "object", "additionalProperties": false, "required": ["receipt_id", "summary"], "properties": {"receipt_id": {"type": "string"}, "summary": {"type": "string", "maxLength": 1000}}}}}},
    "capabilities": {"type": "array", "maxItems": 64, "items": {"type": "object", "additionalProperties": false, "required": ["operation_id", "provider", "effect", "gate"], "properties": {"operation_id": {"type": "string"}, "provider": {"type": "string"}, "effect": {"enum": ["read", "state_mutation", "external_effect", "policy_mutation"]}, "gate": {"enum": ["none", "preview", "approval"]}, "summary": {"type": "string", "maxLength": 500}}}},
    "skills": {"type": "array", "maxItems": 16, "items": {"type": "object", "additionalProperties": false, "required": ["id", "digest", "purpose"], "properties": {"id": {"type": "string"}, "digest": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"}, "purpose": {"type": "string", "maxLength": 500}}}},
    "constraints": {"type": "object", "additionalProperties": false, "required": ["turn_limit", "tool_limit", "stop_conditions"], "properties": {"turn_limit": {"type": "integer", "minimum": 1, "maximum": 100}, "tool_limit": {"type": "integer", "minimum": 0, "maximum": 100}, "stop_conditions": {"type": "array", "minItems": 1, "maxItems": 32, "items": {"type": "string", "maxLength": 500}}}},
    "evidence": {"type": "array", "maxItems": 32, "items": {"type": "object", "additionalProperties": false, "required": ["citation", "summary"], "properties": {"citation": {"type": "string", "maxLength": 500}, "summary": {"type": "string", "maxLength": 2000}}}}
  }
}
