{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://fakoli.dev/anvil-workbench/contracts/bridge-command.v1.schema.json",
  "title": "Anvil Workbench bridge command v1",
  "description": "Authenticated hub-to-bridge delivery envelope. The payload identifies a reviewed adapter request; it is never an executable shell command or credential container. The bridge revalidates all digests and typed payloads against its local configured catalogs before an effect.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "command_id", "kind", "run_id", "bridge_id", "project_id", "workflow_snapshot", "lease", "idempotency_key", "issued_at", "expires_at", "payload"],
  "properties": {
    "schema_version": {"const": "workbench-bridge-command/v1"},
    "command_id": {"type": "string", "pattern": "^cmd_[a-zA-Z0-9_-]{8,128}$"},
    "kind": {"enum": ["run_codex", "invoke_operation", "skill_probe", "commit_pr", "merge_and_accept"]},
    "run_id": {"type": "string"},
    "bridge_id": {"type": "string"},
    "project_id": {"type": "string"},
    "workflow_snapshot": {"type": "object", "additionalProperties": false, "required": ["workflow_digest", "catalogs", "capability_profile_digest"], "properties": {"workflow_digest": {"$ref": "#/$defs/digest"}, "catalogs": {"type": "array", "minItems": 1, "maxItems": 16, "items": {"type": "object", "additionalProperties": false, "required": ["provider", "digest"], "properties": {"provider": {"type": "string"}, "digest": {"$ref": "#/$defs/digest"}}}}, "capability_profile_digest": {"$ref": "#/$defs/digest"}}},
    "lease": {"type": "object", "additionalProperties": false, "required": ["worktree_name", "epoch"], "properties": {"worktree_name": {"type": "string", "pattern": "^[a-zA-Z0-9._-]{1,128}$"}, "epoch": {"type": "integer", "minimum": 1}}},
    "correlation": {"type": "object", "additionalProperties": false, "properties": {"task_id": {"type": "string"}, "request_id": {"type": "string"}, "traceparent": {"type": "string", "maxLength": 256}}},
    "idempotency_key": {"type": "string", "pattern": "^[a-zA-Z0-9:._-]{8,256}$"},
    "approval_grant_id": {"type": "string", "pattern": "^approval_[a-zA-Z0-9_-]{8,128}$"},
    "issued_at": {"type": "string", "format": "date-time"},
    "expires_at": {"type": "string", "format": "date-time"},
    "payload": {"type": "object"}
  },
  "allOf": [
    {"if": {"properties": {"kind": {"const": "invoke_operation"}}}, "then": {"properties": {"payload": {"$ref": "#/$defs/invoke_operation"}}}},
    {"if": {"properties": {"kind": {"const": "run_codex"}}}, "then": {"properties": {"payload": {"$ref": "#/$defs/run_codex"}}}},
    {"if": {"properties": {"kind": {"const": "skill_probe"}}}, "then": {"properties": {"payload": {"$ref": "#/$defs/skill_probe"}}}},
    {"if": {"properties": {"kind": {"const": "commit_pr"}}}, "then": {"required": ["approval_grant_id"], "properties": {"payload": {"allOf": [{"$ref": "#/$defs/approved_effect"}, {"properties": {"action": {"const": "commit_pr"}}}]}}}},
    {"if": {"properties": {"kind": {"const": "merge_and_accept"}}}, "then": {"required": ["approval_grant_id"], "properties": {"payload": {"allOf": [{"$ref": "#/$defs/approved_effect"}, {"properties": {"action": {"const": "merge_and_accept"}}}]}}}}
  ],
  "$defs": {
    "digest": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"},
    "operation": {"type": "object", "additionalProperties": false, "required": ["provider", "id", "contract_version", "operation_digest"], "properties": {"provider": {"type": "string"}, "id": {"type": "string"}, "contract_version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"}, "operation_digest": {"$ref": "#/$defs/digest"}}},
    "invoke_operation": {"type": "object", "additionalProperties": false, "required": ["operation", "inputs"], "properties": {"operation": {"$ref": "#/$defs/operation"}, "inputs": {"type": "object"}, "approval": {"type": "object", "additionalProperties": false, "required": ["grant_id", "action", "payload_hash"], "properties": {"grant_id": {"type": "string", "pattern": "^approval_[a-zA-Z0-9_-]{8,128}$"}, "action": {"enum": ["commit_pr", "merge_and_accept", "deployment", "model_policy"]}, "payload_hash": {"$ref": "#/$defs/digest"}}}}},
    "run_codex": {"type": "object", "additionalProperties": false, "required": ["run_context_id"], "properties": {"run_context_id": {"type": "string", "pattern": "^ctx_[a-zA-Z0-9_-]{8,128}$"}}},
    "skill_probe": {"type": "object", "additionalProperties": false, "required": ["skills"], "properties": {"skills": {"type": "array", "minItems": 1, "maxItems": 64, "items": {"type": "object", "additionalProperties": false, "required": ["id", "digest"], "properties": {"id": {"type": "string"}, "digest": {"$ref": "#/$defs/digest"}}}}}},
    "approved_effect": {"type": "object", "additionalProperties": false, "required": ["action", "approval_payload_hash", "operation"], "properties": {"action": {"enum": ["commit_pr", "merge_and_accept"]}, "approval_payload_hash": {"$ref": "#/$defs/digest"}, "operation": {"$ref": "#/$defs/operation"}, "observed_refs": {"type": "object", "maxProperties": 16, "propertyNames": {"pattern": "^[a-z][a-z0-9_]{0,63}$"}, "additionalProperties": {"type": "string", "pattern": "^[A-Za-z0-9._:/-]{1,160}$"}}}}
  }
}
