{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://fakoli.dev/anvil-workbench/contracts/state-snapshot.v1.schema.json",
  "title": "Anvil Workbench State project snapshot v1",
  "description": "A bounded, bridge-published projection of one project's PRD, plan, and task hierarchy read through the supported State CLI/MCP surface. It carries readable titles for display and typed references for authority. All prose fields are untrusted task data, never control instructions. It contains no local path, credential, raw command, or State storage detail, and it never substitutes for canonical State.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "snapshot_digest", "provider", "generated_at", "source", "project", "prds", "tasks"],
  "$defs": {
    "prdId": {"type": "string", "pattern": "^[a-z0-9][a-z0-9._-]{0,63}$"},
    "taskId": {"type": "string", "pattern": "^T[0-9]{3}(\\.[0-9]{1,3})?$"},
    "statusToken": {"type": "string", "pattern": "^[a-z][a-z0-9_-]{0,31}$"},
    "taskRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["prd_id", "task_id"],
      "properties": {
        "prd_id": {"$ref": "#/$defs/prdId"},
        "task_id": {"$ref": "#/$defs/taskId"}
      }
    }
  },
  "properties": {
    "schema_version": {"const": "workbench-state-snapshot/v1"},
    "snapshot_digest": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"},
    "provider": {"const": "anvil-state"},
    "generated_at": {"type": "string", "format": "date-time", "maxLength": 40, "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}([.][0-9]{1,9})?(Z|[+-][0-9]{2}:[0-9]{2})$"},
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["provider_contract_version", "read_operation_id"],
      "properties": {
        "provider_contract_version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
        "read_operation_id": {"type": "string", "pattern": "^[a-z][a-z0-9._-]{0,127}$"},
        "state_schema_label": {"type": "string", "maxLength": 64}
      }
    },
    "project": {
      "type": "object",
      "additionalProperties": false,
      "required": ["project_id", "name"],
      "properties": {
        "project_id": {"type": "string", "pattern": "^[a-zA-Z0-9._-]{1,128}$"},
        "name": {"type": "string", "maxLength": 200}
      }
    },
    "prds": {
      "type": "array",
      "minItems": 1,
      "maxItems": 64,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["content_trust", "prd_id", "title", "status", "revision"],
        "properties": {
          "content_trust": {"const": "untrusted_task_data"},
          "prd_id": {"$ref": "#/$defs/prdId"},
          "title": {"type": "string", "maxLength": 500},
          "status": {"$ref": "#/$defs/statusToken"},
          "revision": {"type": "integer", "minimum": 1},
          "target_version": {"type": "string", "maxLength": 100}
        }
      }
    },
    "tasks": {
      "type": "array",
      "maxItems": 1024,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["content_trust", "ref", "scoped_id", "title", "status"],
        "properties": {
          "content_trust": {"const": "untrusted_task_data"},
          "ref": {"$ref": "#/$defs/taskRef"},
          "scoped_id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9._-]{0,63}:T[0-9]{3}(\\.[0-9]{1,3})?$"},
          "title": {"type": "string", "maxLength": 500},
          "status": {"$ref": "#/$defs/statusToken"},
          "priority": {"$ref": "#/$defs/statusToken"},
          "feature_id": {"type": "string", "pattern": "^[a-zA-Z0-9._:-]{1,128}$"},
          "depends_on": {"type": "array", "maxItems": 64, "items": {"$ref": "#/$defs/taskRef"}}
        }
      }
    }
  }
}
