{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://fakoli.dev/anvil-workbench/contracts/model-proposal.v1.schema.json",
  "title": "Anvil Workbench model proposal v1",
  "description": "The bounded proposal returned for the next inference action. It is validated by the hub and bridge and is never an authority grant or executable command.",
  "oneOf": [{"$ref": "#/$defs/progress"}, {"$ref": "#/$defs/operation_request"}, {"$ref": "#/$defs/clarification_request"}, {"$ref": "#/$defs/approval_request"}, {"$ref": "#/$defs/reconcile"}],
  "$defs": {
    "base": {"type": "object", "required": ["schema_version", "kind", "reason"], "properties": {"schema_version": {"const": "workbench-model-proposal/v1"}, "kind": {"type": "string"}, "reason": {"type": "string", "minLength": 1, "maxLength": 2000}}},
    "operation_ref": {"type": "object", "additionalProperties": false, "required": ["provider", "id", "contract_version", "operation_digest"], "properties": {"provider": {"type": "string"}, "id": {"type": "string"}, "contract_version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"}, "operation_digest": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"}}},
    "progress": {"allOf": [{"$ref": "#/$defs/base"}, {"type": "object", "additionalProperties": false, "required": ["schema_version", "kind", "reason", "summary"], "properties": {"schema_version": {"const": "workbench-model-proposal/v1"}, "kind": {"const": "progress"}, "reason": {"type": "string", "minLength": 1, "maxLength": 2000}, "summary": {"type": "string", "minLength": 1, "maxLength": 4000}}}]},
    "operation_request": {"allOf": [{"$ref": "#/$defs/base"}, {"type": "object", "additionalProperties": false, "required": ["schema_version", "kind", "reason", "operation", "input"], "properties": {"schema_version": {"const": "workbench-model-proposal/v1"}, "kind": {"const": "operation_request"}, "reason": {"type": "string", "minLength": 1, "maxLength": 2000}, "operation": {"$ref": "#/$defs/operation_ref"}, "input": {"type": "object"}}}]},
    "clarification_request": {"allOf": [{"$ref": "#/$defs/base"}, {"type": "object", "additionalProperties": false, "required": ["schema_version", "kind", "reason", "question"], "properties": {"schema_version": {"const": "workbench-model-proposal/v1"}, "kind": {"const": "clarification_request"}, "reason": {"type": "string", "minLength": 1, "maxLength": 2000}, "question": {"type": "string", "minLength": 1, "maxLength": 1000}}}]},
    "approval_request": {"allOf": [{"$ref": "#/$defs/base"}, {"type": "object", "additionalProperties": false, "required": ["schema_version", "kind", "reason", "action"], "properties": {"schema_version": {"const": "workbench-model-proposal/v1"}, "kind": {"const": "approval_request"}, "reason": {"type": "string", "minLength": 1, "maxLength": 2000}, "action": {"enum": ["commit_pr", "merge_and_accept", "deployment", "model_policy"]}}}]},
    "reconcile": {"allOf": [{"$ref": "#/$defs/base"}, {"type": "object", "additionalProperties": false, "required": ["schema_version", "kind", "reason", "known_facts"], "properties": {"schema_version": {"const": "workbench-model-proposal/v1"}, "kind": {"const": "reconcile"}, "reason": {"type": "string", "minLength": 1, "maxLength": 2000}, "known_facts": {"type": "array", "minItems": 1, "maxItems": 32, "items": {"type": "string", "maxLength": 1000}}}}]}
  }
}
