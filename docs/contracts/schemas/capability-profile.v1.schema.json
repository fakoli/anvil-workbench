{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://fakoli.dev/anvil-workbench/contracts/capability-profile.v1.schema.json",
  "title": "Anvil Workbench project capability profile v1",
  "description": "A reviewed project allowlist. It narrows the operations, model profiles, and skills available to a run; it does not grant credentials or override a provider's gate.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "id", "revision", "digest", "operations", "model_profiles", "skills", "limits"],
  "properties": {
    "schema_version": {"const": "workbench-capability-profile/v1"},
    "id": {"type": "string", "pattern": "^[a-z][a-z0-9._-]{1,127}$"},
    "revision": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "digest": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"},
    "operations": {"type": "array", "minItems": 1, "maxItems": 128, "items": {"type": "object", "additionalProperties": false, "required": ["provider", "id", "contract_version", "operation_digest"], "properties": {"provider": {"type": "string"}, "id": {"type": "string"}, "contract_version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"}, "operation_digest": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"}}}},
    "model_profiles": {"type": "array", "minItems": 1, "maxItems": 32, "items": {"type": "string", "pattern": "^[a-z][a-z0-9._-]{1,127}$"}},
    "skills": {"type": "array", "maxItems": 64, "items": {"type": "object", "additionalProperties": false, "required": ["id", "digest"], "properties": {"id": {"type": "string", "pattern": "^[a-z][a-z0-9:_-]{1,127}$"}, "digest": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"}}}},
    "limits": {"type": "object", "additionalProperties": false, "required": ["max_parallel_runs", "max_agent_turns", "max_tool_calls"], "properties": {"max_parallel_runs": {"type": "integer", "minimum": 1, "maximum": 16}, "max_agent_turns": {"type": "integer", "minimum": 1, "maximum": 100}, "max_tool_calls": {"type": "integer", "minimum": 0, "maximum": 100}}},
    "approval_actions": {"type": "array", "items": {"enum": ["commit_pr", "merge_and_accept", "deployment", "model_policy"]}}
  }
}
