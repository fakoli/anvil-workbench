{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://fakoli.dev/anvil-workbench/contracts/operation-catalog.v1.schema.json",
  "title": "Anvil Workbench provider operation catalog v1",
  "description": "A reviewed, provider-owned projection of operations that Workbench may orchestrate through a local bridge. It is not a command manifest and contains no secret, path, shell, or endpoint value.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "provider", "catalog_version", "operations"],
  "properties": {
    "schema_version": {"const": "anvil-operation-catalog/v1"},
    "provider": {"type": "string", "pattern": "^[a-z][a-z0-9-]{1,62}$"},
    "catalog_version": {"type": "string", "minLength": 1, "maxLength": 64},
    "catalog_digest": {"$ref": "#/$defs/sha256"},
    "generated_at": {"type": "string", "format": "date-time"},
    "operations": {
      "type": "array",
      "minItems": 1,
      "maxItems": 256,
      "items": {"$ref": "#/$defs/operation"}
    }
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"},
    "operation_id": {"type": "string", "pattern": "^[a-z][a-z0-9]*(?:[._][a-z0-9]+)*$"},
    "operation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "title", "contract_version", "summary", "effect", "execution", "input_schema", "output_schema", "gates", "receipts", "failure", "docs"],
      "properties": {
        "id": {"$ref": "#/$defs/operation_id"},
        "title": {"type": "string", "minLength": 1, "maxLength": 160},
        "summary": {"type": "string", "minLength": 1, "maxLength": 1000},
        "contract_version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
        "operation_digest": {"$ref": "#/$defs/sha256"},
        "effect": {"enum": ["read", "state_mutation", "external_effect", "policy_mutation"]},
        "execution": {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "bridge_adapter"],
          "properties": {
            "kind": {"const": "bridge_adapter"},
            "bridge_adapter": {"type": "string", "pattern": "^[a-z][a-z0-9]*(?:[._][a-z0-9]+)*$"},
            "transport": {"enum": ["state_cli", "serving_mcp", "serving_cli", "bridge_local"]}
          }
        },
        "input_schema": {"type": "object"},
        "output_schema": {"type": "object"},
        "preconditions": {"type": "array", "maxItems": 32, "items": {"type": "string", "minLength": 1, "maxLength": 160}},
        "gates": {
          "type": "object",
          "additionalProperties": false,
          "required": ["preview", "confirmation", "human_approval"],
          "properties": {
            "preview": {"enum": ["not_supported", "optional", "required"]},
            "confirmation": {"enum": ["not_required", "required"]},
            "human_approval": {"enum": ["not_required", "required"]}
          }
        },
        "idempotency": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "required": {"type": "boolean"},
            "replay": {"enum": ["return_prior_receipt", "reconcile", "not_supported"]},
            "max_attempts": {"type": "integer", "minimum": 1, "maximum": 5}
          }
        },
        "receipts": {"type": "array", "minItems": 1, "maxItems": 16, "items": {"type": "string", "pattern": "^[a-z][a-z0-9._-]{1,127}$"}},
        "failure": {"enum": ["fail", "reconcile"]},
        "docs": {"type": "string", "minLength": 1, "maxLength": 500}
      }
    }
  }
}
